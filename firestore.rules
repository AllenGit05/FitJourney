rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /workouts/{workoutId} { allow read, write: if request.auth.uid == userId; }
      match /diet/{dietId} { allow read, write: if request.auth.uid == userId; }
      match /habits/{habitId} { allow read, write: if request.auth.uid == userId; }
      match /progress/{progressId} { allow read, write: if request.auth.uid == userId; }
      match /water/{waterId} { allow read, write: if request.auth.uid == userId; }
    }
  }
}
